@model IEnumerable<CasoEstudio2.Models.CasasModel>

@{
    ViewBag.Title = "Consulta de Casas";
}

<h2>Consulta de Casas</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Descripción</th>
            <th>Precio Mensual</th>
            <th>Usuario</th>
            <th>Estado</th>
            <th>Fecha Alquiler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var casa in Model)
        {
            <tr>
                <td>@casa.DescripcionCasa</td>
                <td>@casa.PrecioCasa.ToString("N2")</td>
                <td>@casa.UsuarioAlquiler</td>
                <td>
                    @if (casa.Estado == "Disponible")
                    {
                        <span class="label label-success">Disponible</span>
                    }
                    else
                    {
                        <span class="label label-danger">Reservada</span>
                    }
                </td>
                <td>@casa.FechaFormateada</td>
            </tr>
        }
    </tbody>
</table>

@Html.ActionLink("Alquilar una Casa", "Alquiler", "Casas", null, new { @class = "btn btn-primary" })