@model IEnumerable<CasoEstudio2.EntityFramework.CasasSistema>
@{
    ViewBag.Title = "Consulta de Casas";
}

<h2 class="mt-4 mb-4">Consulta de Casas</h2>

<table class="table table-striped table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Usuario</th>
            <th>Estado</th>
            <th>Fecha de Alquiler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.DescripcionCasa)
                </td>
                <td>
                    @item.PrecioCasa.ToString("C")
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.UsuarioAlquiler)
                </td>
                <td>
                    @{
                        var esDisponible = string.IsNullOrEmpty(item.UsuarioAlquiler);
                        var badgeClass = esDisponible ? "bg-success text-white" : "bg-secondary text-white";
                        var texto = esDisponible ? "Disponible" : "Reservada";
                    }

                    <span class="badge @badgeClass">
                        @texto
                    </span>
                </td>
                <td>
                    @(item.FechaAlquiler.HasValue 
                        ? item.FechaAlquiler.Value.ToString("dd/MM/yyyy") 
                        : "N/A")
                </td>
            </tr>
        }
    </tbody>
</table>