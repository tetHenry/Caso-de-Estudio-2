@{
    ViewBag.Title = "Home";
}

<div class="card">
    <h2>Bienvenido</h2>

    <p style="color: var(--color-muted); margin-bottom: 32px; font-size: 0.95rem;">
        Gestiona la consulta y el alquiler de casas disponibles desde el menú superior.
    </p>

    <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        <a href="@Url.Action("Consulta", "Casas")" class="btn-primary">
            Ver Consulta de Casas
        </a>
        <a href="@Url.Action("Alquiler", "Casas")" class="btn-secondary">
            Alquilar una Casa
        </a>
    </div>
</div>
